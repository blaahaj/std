{
  "name": "@blaahaj/std",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "exports": {
    "./eslint": "./dist/src/eslint/index.js",
    "./npjl": "./dist/src/npm-package-json-lint/index.js",
    "./npm-package-json-lint": "./dist/src/npm-package-json-lint/index.js"
  },
  "main": "index.js",
  "bin": {
    "std-fix-npmPkgJsonLint": "./dist/src/npm-package-json-lint/fix.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "format": "node --enable-source-maps ./dist/src/npm-package-json-lint/fix.js && eslint --fix --fix-type layout src test && prettier --write --list-different .",
    "test": "concurrently --group=true pnpm:test:\\*",
    "test:format": "prettier --check .",
    "test:lint": "eslint src test",
    "test:package-json": "npmPkgJsonLint .",
    "test:unit": "node --enable-source-maps --test './test/**/*.test.ts'"
  },
  "dependencies": {
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "npm-package-json-lint": "^10.4.0",
    "npm-package-json-lint-config-default": "^9.0.1",
    "prettier": "^3.8.4",
    "prettier-cli": "^0.1.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "download",
      "version": "^11.7.0"
    }
  }
}
